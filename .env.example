# LLM API (via OpenRouter — supports GPT-4o, Claude, Gemini, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o

# Excel template path (relative to project root)
EXCEL_TEMPLATE_PATH=Checklist模板.xlsx

# Server port (Railway sets this automatically; override locally)
# PORT=8088
